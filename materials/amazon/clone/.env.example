# External SMTP example only. Never commit real credentials.
# The zero-secret local SMTP inbox does not read this file; run start-local.ps1.
AMAZON_CLONE_SMTP_HOST=smtp.example.com
AMAZON_CLONE_SMTP_PORT=587
AMAZON_CLONE_SMTP_TLS=starttls
AMAZON_CLONE_SMTP_FROM=Amazon Clone <no-reply@example.com>
AMAZON_CLONE_SMTP_USERNAME=replace-with-provider-username
AMAZON_CLONE_SMTP_PASSWORD=replace-with-provider-app-password
AMAZON_CLONE_SMTP_TIMEOUT_SECONDS=10
AMAZON_CLONE_REQUIRE_SMTP=1
