# Runtime and optional external SMTP names only. Never commit real credentials.
# Permanent public demo defaults (Render sets these from render.yaml).
AMAZON_HOST=0.0.0.0
AMAZON_DB_PATH=/data/amazon.sqlite3
AMAZON_ADMIN_HOST=127.0.0.1
AMAZON_ADMIN_PORT=8154
AMAZON_ADMIN_TOKEN=replace-with-at-least-32-random-characters
AMAZON_BASIC_AUTH_USERNAME=bench
AMAZON_BASIC_AUTH_PASSWORD=replace-with-a-deploy-time-secret
AMAZON_COOKIE_SECURE=1
AMAZON_HSTS=1
AMAZON_NOINDEX=1

# The zero-secret local SMTP inbox does not read this file; run start-local.ps1.
AMAZON_CLONE_SMTP_HOST=smtp.example.com
AMAZON_CLONE_SMTP_PORT=587
AMAZON_CLONE_SMTP_TLS=starttls
AMAZON_CLONE_SMTP_FROM=Amazon Clone <no-reply@example.com>
AMAZON_CLONE_SMTP_USERNAME=replace-with-provider-username
AMAZON_CLONE_SMTP_PASSWORD=replace-with-provider-app-password
AMAZON_CLONE_SMTP_TIMEOUT_SECONDS=10
AMAZON_CLONE_REQUIRE_SMTP=1
