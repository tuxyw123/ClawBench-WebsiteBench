{
  "format": "clawbench.amazon.phase4-browseruse.v1",
  "gate": 4,
  "browserUse": {
    "package": "browser-use",
    "version": "0.12.6",
    "driver": "Browser + Tools",
    "controller": "current-codex-deterministic",
    "additionalLlmCalls": 0,
    "userAgentPolicy": {
      "desktop": "Chromium Linux desktop",
      "mobileAtOrBelow480px": "Chromium Android Mobile"
    },
    "modelProvenance": {
      "model": "gpt-5.6-sol",
      "reasoningEffort": "xhigh",
      "source": "/root/.codex/config.toml"
    }
  },
  "sourceSafety": {
    "allowedRequestMethods": ["GET"],
    "blockedAt": "CDP Fetch.requestPaused",
    "blockedWith": "Fetch.failRequest(BlockedByClient)",
    "credentials": "anonymous",
    "forbidSourceCartMutation": true,
    "forbidSourceIdentityFlow": true,
    "forbidSourceFormSubmission": true,
    "forbidSourceCheckout": true
  },
  "locale": {
    "language": "en-US",
    "currency": "USD",
    "deliveryRegion": "New York 10001"
  },
  "trajectories": [
    {
      "id": "B01",
      "name": "Best Sellers to exact product",
      "viewport": "desktop",
      "source": [
        "GET Best Sellers root",
        "inspect or follow External Solid State Drives link",
        "inspect or follow ASIN B0874XN4D8",
        "inspect product title, quantity, and Add to Cart affordance",
        "stop before source mutation"
      ],
      "clone": [
        "open Best Sellers root",
        "click External Solid State Drives link",
        "click rank 2 ASIN B0874XN4D8",
        "select quantity 2",
        "click Add to Cart",
        "verify cart quantity 2 and subtotal $439.98"
      ],
      "mutationPolicy": "clone-only"
    },
    {
      "id": "B02",
      "name": "Search, autocomplete, department, and sort",
      "viewport": "desktop",
      "source": [
        "GET portable ssd search",
        "inspect result cards and refinement controls",
        "stop before source quick-add"
      ],
      "clone": [
        "type portable ssd in the header search",
        "submit with Enter",
        "inspect populated results",
        "choose Computers department",
        "choose Price: Low to High",
        "verify refined sorted results"
      ],
      "mutationPolicy": "read-only-both"
    },
    {
      "id": "B03",
      "name": "Anonymous account boundary",
      "viewport": "desktop",
      "source": [
        "GET Your Account entry",
        "inspect anonymous account affordances",
        "stop before sign-in"
      ],
      "clone": [
        "open Your Account",
        "inspect local sign-in and account-creation affordances",
        "open Your Orders",
        "verify local sign-in-required boundary with no external navigation"
      ],
      "mutationPolicy": "read-only-both"
    },
    {
      "id": "B04",
      "name": "Anonymous empty cart",
      "viewport": "desktop",
      "source": [
        "GET cart in an anonymous session",
        "inspect empty-cart semantics"
      ],
      "clone": [
        "GET cart in a fresh isolated session",
        "verify empty-cart semantics and zero subtotal"
      ],
      "mutationPolicy": "read-only-both"
    },
    {
      "id": "B05",
      "name": "Mobile ranked discovery and product controls",
      "viewport": "mobile",
      "source": [
        "GET External Solid State Drives ranking",
        "inspect mobile ranking state",
        "GET mobile ASIN B0874XN4D8 product page",
        "inspect quantity and Add to Cart affordance",
        "stop before source mutation"
      ],
      "clone": [
        "open mobile External Solid State Drives ranking",
        "click rank 2 ASIN B0874XN4D8",
        "inspect quantity and Add to Cart controls",
        "stop because desktop clone session already proves the exact mutation"
      ],
      "mutationPolicy": "read-only-prefix-both"
    }
  ],
  "gateCriteria": {
    "browserUseVersionExact": true,
    "additionalLlmCalls": 0,
    "sourceNonGetTransmitted": 0,
    "sourceMutationsExecuted": 0,
    "cloneExternalNavigations": 0,
    "clonePostCount": 1,
    "cloneTerminalPostCount": 1,
    "cloneTaskTerminalReached": true,
    "cloneTaskQuantity": 2,
    "cloneTaskSubtotal": "$439.98",
    "cloneEmptyCartCheckoutAffordance": false,
    "requiredTrajectoryCount": 5,
    "manualReviewRequired": true
  }
}
