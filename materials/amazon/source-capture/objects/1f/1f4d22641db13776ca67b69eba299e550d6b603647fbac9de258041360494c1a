gement and safety, T7 maintains its outer casing temperature below 118.4o F, except when the ambient temperature is above 118.4 F. ******Software requires Windows 7 and higher, Mac OS X 10.10 and higher, or Android 5.1 (Lollipop) and higher. Older versions of the Windows, Mac, and Android operating systems may not be supported. Firmware update requires PC or Mac and internet connection. Android app available on Google Play. *******Compatibility with host devices may vary. Some operating systems may require T7 Touch reformatting. Please find the compatible devices list on Samsung.com/support. T7 Touch is compatible with USB 3.0 and USB 2.0. ********Source: 2003-Q3 2020 IHS Markit data: NAND suppliers' revenue market share."}}]},"properties":[],"parentId":"3987","childIds":["-1000000393","-1000000394","-1000000395","-1000000396","-1000000397","-1000000398","-1000000399","-1000000400","-1000000401","-1000000402","-1000000403","-1000000404","-1000000405","-1000000406","-1000000407"],"backendDOMNodeId":6862},{"nodeId":"-1000000409","ignored":false,"role":{"type":"internalRole","value":"InlineTextBox"},"chromeRole":{"type":"internalRole","value":101},"name":{"type":"computedString","value":"Safety documents"},"properties":[],"parentId":"6864","childIds":[]},{"nodeId":"6865","ignored":false,"role":{"type":"internalRole","value":"StaticText"},"chromeRole":{"type":"internalRole","value":158},"name":{"type":"computedString","value":"User Manual (PDF)","sources":[{"type":"contents","value":{"type":"computedString","value":"User Manual (PDF)"}}]},"properties":[],"parentId":"4014","childIds":["-1000000410"],"backendDOMNodeId":6865},{"nodeId":"-1000000412","ignored":true,"ignoredReasons":[{"name":"presentationalRole","value":{"type":"boolean","value":true}}],"role":{"type":"role","value":"none"},"chromeRole":{"type":"internalRole","value":0},"parentId":"6867","childIds":[]},{"nodeId":"-1000000413","ignored":false,"role":{"type":"internalRole","value":"InlineTextBox"},"chromeRole