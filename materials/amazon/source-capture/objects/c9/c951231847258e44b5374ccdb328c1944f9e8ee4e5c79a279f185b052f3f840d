            var indicatorIndex = activePageNumber - 1;

            $carousel.find(".sl-sobe-carousel-page-indicator > .active").removeClass("active");
            
            $carousel.find(".sl-sobe-carousel-page-indicator").children().eq(indicatorIndex).addClass("active");
            
            if (activePageNumber > 7.0) {
                
                $carousel.find(".sl-sobe-carousel-page-indicator").children().eq(0).addClass("active");
            }
            
            state.activePageNumber = activePageNumber;
        }

        function onUserInputAction(event) {
            if (state.userInputType != null) { return; }
            state.userInputType = event.type === "touchstart" ? "touch" : "mouse";
            if (state.userInputType === "mouse" && state.scrollable) {
                var $nav = $carousel.find(".sl-sobe-carousel-nav");
                $nav.find(".sl-sobe-carousel-goto-prevpage").click({type: "prev"}, onNavButtonClick);
                $nav.find(".sl-sobe-carousel-goto-nextpage").click({type: "next"}, onNavButtonClick);
                $scroller.mousedown(onDragScrollerStart);
            }
            
            if (state.userInputType === "touch" && state.scrollable) {
                let touchStartX;
                let touchStartY;
                let touchStartScrollLeft;
                let touchStartHandler = function(event) {
                    const touch = event.originalEvent.touches[0] || event.originalEvent.changedTouches[0];
                    touchStartX = touch.pageX;
                    touchStartY = touch.pageY;
                    touchStartScrollLeft = state.getViewportScrollLeft();
                    
                    
                    clearTimeout(state.autoScrollTimeout);
                    
                }
                touchStartHandler(event);
                $viewport.bind("touchstart", touchStartHandler)
                    .bind("touchend touchcancel", function (event) {
                    const touch = event.originalEvent.touches[0] || event.originalEvent.changedTouches[0];
                    let touchEndX = touch.pageX;
                    let touchEndY = touch.pageY;
                    let scrollLeft;
                    const swipeScrollDirectionThreshold = 2;
                    
                    if (Math.abs(touchStartX - touchEndX) / Math.abs(touchStartY - touchEndY) > swipeScrollDirectionThreshold) {
                        
                        const bounds = state.getScrollBounds();
                        if (touchStartX < touchEndX) {
                            scrollLeft = Math.min(Math.max(touchStartScrollLeft - state.getPaginationWidth(), bounds.min), bounds.max);
                        } else {
                            scrollLeft = Math.max(Math.min(touchStartScrollLeft + state.getPaginationWidth(), bounds.max), bounds.min);
                        }
                    } else {
                        
                        scrollLeft = touchStartScrollLeft;
                    }
                    
                    
                    scrollLeft = Math.round(scrollLeft / state.getPaginationWidth()) * state.getPaginationWidth();
                    
                    
                    
                    state.autoScrollTimeout = setTimeout(autoScroll, AUTO_SCROLL_TIMEOUT);
                    
                    $viewport.animate({
                        scrollLeft: scrollLeft
                    }, onViewportScroll);
                });
            }
            
            $carousel.attr("userInputType", state.userInputType);
        }

        function onViewportScroll() {
            if (state.viewportScrolling) {
                return;
            }
            state.viewportScrolling = true;
            requestAnimationFrame(onViewportScrollAnimation);
        }

        function onViewportScrollAnimation() {
            
            var normalizedScrollLeft = Math.abs($viewport[0].scrollLeft);
            var maxScrollLeft = state.getViewportMaxScrollLeft();
            state.scrollRatio = maxScrollLeft > 0 ? normalizedScrollLeft / maxScrollLeft : 0;

            var scrollerPosition = state.scrollRatio * (state.viewportWidth - state.getScrollerWidth());
            
            $scroller.css({
                "left": scrollerPosition
            });

            var scrollPct = state.scrollRatio * 100;
            if (scrollPct < 0.1) {
                scrollPct = 0;
            } else if (scrollPct > 99.9) {
                scrollPct = 100;
            }
            $carousel.attr("scrollPct", scrollPct);

            if (state.userInputType === "touch") {
                $carousel.addClass("scrolling");
                if (state.scrollTimeout != null) {
                    clearTimeout(state.scrollTimeout);
                }
                state.scrollTimeout = setTimeout(function () {
                    $carousel.addClass("scrolling");
                }, 1000);
            }

            
            
            const rawScrollLeft = $viewport[0].scrollLeft;
            const maxScroll = state.getViewportMaxScrollLeft();
            if (rawScrollLeft === 0) {
                
                $viewport.scrollLeft(getScrollLeftForPage(7.0 + 1));
            } else if (Math.abs(rawScrollLeft) >= maxScroll * 0.99) {
                
                $viewport.scrollLeft(getScrollLeftForPage(2));
            }
            

            if (state.showPageIndicator) {
                updatePageIndicator();
            }
            state.viewportScrolling = false;
        }

        function onDragScrollerStart(event) {
            $carousel.addClass("scrolling");
            $(document).bind("mousemove", onDragScroller);
            $(document).one("mouseup", onDragScrollerEnd);
            state.pageX = event.pageX;
        }

        function onDragScroller(event) {
            var deltaScrollRatio = (event.pageX - state.pageX) / state.viewportWidth;
            
            $viewport[0].scrollLeft += deltaScrollRatio * state.viewportScrollWidth;
            
            state.pageX = event.pageX;
        }

        function onDragScrollerEnd(event) {
            $carousel.removeClass("scrolling");
            $(document).unbind("mousemove", onDragScroller);
        }

        function onNavButtonClick(event) {
            event.preventDefault();
            var scrollLeft = state.getViewportScrollLeft();
            
            var buttonType = event.data.type;

            
            const bounds = state.getScrollBounds();
            if (buttonType === "prev") {
                scrollLeft = Math.min(Math.max(scrollLeft - state.getPaginationWidth(), bounds.min), bounds.max);
            } else if (buttonType === "next") {
                scrollLeft = Math.max(Math.min(scrollLeft + state.getPaginationWidth(), bounds.max), bounds.min);
            }
            
            
            
            scrollLeft = Math.round(scrollLeft / state.getPaginationWidth()) * state.getPaginationWidth();
            

            
            
            clearTimeout(state.autoScrollTimeout);
            state.autoScrollTimeout = setTimeout(autoScroll, AUTO_SCROLL_TIMEOUT);
            
            $viewport.animate({
                scrollLeft: scrollLeft
            }, onViewportScroll);
        }

        function onPageIndicatorDotClick(event){
            event.preventDefault();
            let pageNumber = event.target.getAttribute("data-page-number");

            
            pageNumber++;
            

            scrollToPage(pageNumber);

            
            
            clearTimeout(state.autoScrollTimeout);
            state.autoScrollTimeout = setTimeout(autoScroll, AUTO_SCROLL_TIMEOUT);
            
        }

        /**
         * Returns the scrollLeft value to position the viewport at the given 1-based page number.
         * In RTL mode scrollLeft is negative; in LTR it is positive.
         */
        function getScrollLeftForPage(pageNumber) {
            return state.isRTL
                ? -(pageNumber - 1) * state.getPaginationWidth()
                : (pageNumber - 1) * state.getPaginationWidth();
        }

        function scrollToPage(pageNumber){
            const scrollLeft = getScrollLeftForPage(pageNumber);
            $viewport.animate({
                scrollLeft: scrollLeft
            }, onViewportScroll);
        }

        function autoScroll() {
            let scrollLeft = state.getViewportScrollLeft();

            
            const advanceStep = state.isRTL ? -state.getPaginationWidth() : state.getPaginationWidth();
            const bounds = state.getScrollBounds();
            scrollLeft = Math.min(Math.max(scrollLeft + advanceStep, bounds.min), bounds.max);

            
            
            scrollLeft = Math.round(scrollLeft / state.getPaginationWidth()) * state.getPaginationWidth();
            
            $viewport.animate({
                scrollLeft: scrollLeft
            }, 400, onViewportScroll);
            
            // Timer reset logic preserved for both directions
            state.autoScrollTimeout = setTimeout(autoScroll, AUTO_SCROLL_TIMEOUT);
        }

        function copyFirstAndLastPage() {
            const $viewPortRowInner = $viewport.find(".sl-sobe-carousel-viewport-row-inner");
            const $firstPage = $viewPortRowInner.find("li.sl-sobe-carousel-sub-card").first().clone();
            const $lastPage = $viewPortRowInner.find("li.sl-sobe-carousel-sub-card").last().clone();
            $firstPage.prop("id", $firstPage.attr("id") + "_clone");
            $firstPage.find('a').contents().unwrap();
            $lastPage.prop("id", $lastPage.attr("id") + "_clone");
            $lastPage.find('a').contents().unwrap();
            $viewPortRowInner.prepend($lastPage);
            $viewPortRowInner.append($firstPage);
        }

        function scrollToClosestPage() {
            const activePageNumber = Math.round(state.getViewportScrollLeft() / state.viewportWidth);
            $viewport.scrollLeft(activePageNumber * state.getPaginationWidth());
        }

        function detectPageDirection() {
            var dir = document.dir || document.documentElement.dir || "";
            return dir.toLowerCase() === "rtl";
        }

        function init() {
            state.isRTL = detectPageDirection();
            
            // Set dir attribute on carousel for CSS selectors
            if (state.isRTL) {
                $carousel.attr("dir", "rtl");
            }
            
            $viewport.bind("mousemove touchstart", onUserInputAction);
            $viewport.scroll(onViewportScroll);
            $(window).resize(function () {
                setTimeout(onResize, 10);
            });
            state.updateViewportDimensions();

            if (IS_UNBUNDLED_HORIZONTAL) {
                state.scrollable = state.viewportScrollWidth > state.viewportWidth;
            } else {
                state.scrollable = true;
            }
            state.showPageIndicator = true;
            if (state.scrollable) {
                if(state.showPageIndicator){
                    $carousel.find(".sl-sobe-carousel-page-indicator > .dot").click(onPageIndicatorDotClick);
                }
                
                state.autoScrollTimeout = setTimeout(autoScroll, AUTO_SCROLL_TIMEOUT);
                

                
                copyFirstAndLastPage();
                state.updateViewportDimensions();
                
                $viewport.scrollLeft(getScrollLeftForPage(2));
                updatePageIndicator();
                

                $carousel.addClass("scrollable");
                $viewport.scroll();
            }
            $carousel.css("visibility", "visible");
        }

        init();
    });
</script>



