        function getThankYouDiv(thankMsg) {
            return (
                '<div class="a-box a-alert a-alert-success a-spacing-mini">' +
                '<div class="a-box-inner a-alert-container"><i class="a-icon a-icon-alert"></i><div class="a-alert-content">' +
                thankMsg +
                '</div></div></div>\n' +
                '<p></p><hr/><p></p>'
