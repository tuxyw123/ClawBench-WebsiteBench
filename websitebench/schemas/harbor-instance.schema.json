{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawbench.local/schemas/harbor-instance.schema.json",
  "title": "ClawBench Harbor instance authoring manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "instance_id",
    "site_manifest",
    "task",
    "metadata",
    "budgets",
    "paths",
    "tests",
    "calibration"
  ],
  "properties": {
    "schema_version": {
      "const": "clawbench.harbor.instance.v1"
    },
    "instance_id": {
      "$ref": "#/$defs/slug"
    },
    "site_manifest": {
      "$ref": "#/$defs/relative_path"
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "type",
        "language"
      ],
      "properties": {
        "category": {
          "const": "web-development"
        },
        "type": {
          "const": "fullstack-reconstruction"
        },
        "language": {
          "const": "web"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "author_name",
        "author_email",
        "difficulty"
      ],
      "properties": {
        "author_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "author_email": {
          "type": "string",
          "format": "email",
          "maxLength": 254
        },
        "difficulty": {
          "enum": [
            "medium",
            "hard",
            "expert"
          ]
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/slug"
          }
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_timeout_sec",
        "verifier_timeout_sec",
        "build_timeout_sec",
        "cpus",
        "memory_mb",
        "storage_mb"
      ],
      "properties": {
        "agent_timeout_sec": {
          "type": "integer",
          "minimum": 60,
          "maximum": 86400
        },
        "verifier_timeout_sec": {
          "type": "integer",
          "minimum": 60,
          "maximum": 86400
        },
        "build_timeout_sec": {
          "type": "integer",
          "minimum": 60,
          "maximum": 86400
        },
        "cpus": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "memory_mb": {
          "type": "integer",
          "minimum": 256,
          "maximum": 262144
        },
        "storage_mb": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 1048576
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instruction",
        "public",
        "verifier",
        "hidden_fixtures",
        "oracle_solution"
      ],
      "properties": {
        "instruction": {
          "$ref": "#/$defs/relative_path"
        },
        "public": {
          "$ref": "#/$defs/relative_path"
        },
        "verifier": {
          "$ref": "#/$defs/relative_path"
        },
        "hidden_fixtures": {
          "$ref": "#/$defs/relative_path"
        },
        "oracle_solution": {
          "$ref": "#/$defs/relative_path"
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "api",
        "ui",
        "visual",
        "journey",
        "robustness"
      ],
      "properties": {
        "contract": {
          "$ref": "#/$defs/test_nodes"
        },
        "api": {
          "$ref": "#/$defs/test_nodes"
        },
        "ui": {
          "$ref": "#/$defs/test_nodes"
        },
        "visual": {
          "$ref": "#/$defs/test_nodes"
        },
        "journey": {
          "$ref": "#/$defs/test_nodes"
        },
        "robustness": {
          "$ref": "#/$defs/test_nodes"
        },
        "efficiency": {
          "$ref": "#/$defs/optional_test_nodes"
        }
      }
    },
    "calibration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nop_max_score",
        "oracle_min_score"
      ],
      "properties": {
        "nop_max_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "oracle_min_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 100
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "node": {
      "type": "string",
      "pattern": "^[a-z]+::[a-z0-9][a-z0-9_.:/-]*$",
      "maxLength": 256
    },
    "test_nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "optional_test_nodes": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/node"
      }
    }
  }
}
