{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawbench.local/schemas/websitebench.result.v1.json",
  "title": "Web2Code2Web evaluation result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "site_id", "site_version", "track", "status",
    "score", "dimensions", "hard_failures", "journeys", "seeds", "resources",
    "network", "failures", "evidence", "versions", "usage", "started_at", "finished_at"
  ],
  "properties": {
    "schema_version": {"const": "websitebench.result.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "site_id": {"type": "string", "minLength": 1},
    "site_version": {"type": "string"},
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "display_name"],
      "properties": {
        "model_id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "provider": {"type": ["string", "null"]},
        "harness": {"type": ["string", "null"]},
        "reasoning_effort": {"type": ["string", "null"]}
      }
    },
    "track": {"enum": ["core", "hitl"]},
    "status": {"enum": ["passed", "failed", "hard_failed", "infrastructure_error"]},
    "score": {"type": "number", "minimum": 0, "maximum": 100},
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visual", "interactions", "journeys", "robustness", "efficiency"],
      "properties": {
        "visual": {"$ref": "#/$defs/dimension"},
        "interactions": {"$ref": "#/$defs/dimension"},
        "journeys": {"$ref": "#/$defs/dimension"},
        "robustness": {"$ref": "#/$defs/dimension"},
        "efficiency": {"$ref": "#/$defs/dimension"}
      }
    },
    "hard_failures": {"type": "array", "items": {"$ref": "#/$defs/hard_failure"}},
    "journeys": {"type": "array", "items": {"$ref": "#/$defs/journey"}},
    "seeds": {"type": "array", "items": {"$ref": "#/$defs/seed_result"}},
    "resources": {"$ref": "#/$defs/resources"},
    "network": {"$ref": "#/$defs/network"},
    "failures": {"type": "array", "items": {"$ref": "#/$defs/failure"}},
    "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
    "versions": {"type": "object", "additionalProperties": {"type": "string"}},
    "usage": {"$ref": "#/$defs/usage"},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "max_score", "passed", "total"],
      "properties": {
        "score": {"type": "number", "minimum": 0},
        "max_score": {"type": "number", "minimum": 0},
        "passed": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0}
      }
    },
    "hard_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "evidence_ids"],
      "properties": {
        "code": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "message": {"type": "string", "minLength": 1},
        "evidence_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "journey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "seed", "score", "max_score", "terminal_passed", "checkpoints"],
      "properties": {
        "id": {"type": "string"},
        "seed": {"type": "integer"},
        "score": {"type": "number", "minimum": 0},
        "max_score": {"const": 5},
        "terminal_passed": {"type": "boolean"},
        "checkpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "passed", "expected", "actual", "evidence_ids"],
            "properties": {
              "id": {"type": "string"},
              "passed": {"type": "boolean"},
              "expected": {},
              "actual": {},
              "evidence_ids": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "seed_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seed", "purpose", "reset_passed", "tests_passed", "tests_total"],
      "properties": {
        "seed": {"type": "integer"},
        "purpose": {"type": "string"},
        "reset_passed": {"type": "boolean"},
        "tests_passed": {"type": "integer", "minimum": 0},
        "tests_total": {"type": "integer", "minimum": 0}
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build_seconds", "startup_seconds", "image_bytes", "source_bytes", "peak_memory_bytes", "p95_latency_ms"],
      "properties": {
        "build_seconds": {"type": "number", "minimum": 0},
        "startup_seconds": {"type": "number", "minimum": 0},
        "image_bytes": {"type": "integer", "minimum": 0},
        "source_bytes": {"type": "integer", "minimum": 0},
        "peak_memory_bytes": {"type": "integer", "minimum": 0},
        "p95_latency_ms": {"type": "number", "minimum": 0}
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_requests", "blocked_requests", "reference_requests", "internet_requests"],
      "properties": {
        "runtime_requests": {"type": "integer", "minimum": 0},
        "blocked_requests": {"type": "integer", "minimum": 0},
        "reference_requests": {"type": "integer", "minimum": 0},
        "internet_requests": {"type": "integer", "minimum": 0}
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "severity", "summary", "expected", "actual", "reproduction", "evidence_ids"],
      "properties": {
        "id": {"type": "string"},
        "category": {
          "enum": [
            "build", "startup", "visual", "interaction", "authentication",
            "session", "cart", "checkout", "order", "inventory", "time",
            "persistence", "concurrency", "security", "anti_cheat", "efficiency"
          ]
        },
        "severity": {"enum": ["hard_fail", "critical", "major", "minor"]},
        "summary": {"type": "string", "minLength": 1},
        "expected": {},
        "actual": {},
        "reproduction": {"type": "array", "items": {"type": "string"}},
        "evidence_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "path", "sha256"],
      "properties": {
        "id": {"type": "string"},
        "kind": {"enum": ["screenshot", "action_log", "network_log", "state", "build_log", "test_log", "diff"]},
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "browser_actions", "candidate_builds", "human_messages", "human_minutes"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "browser_actions": {"type": "integer", "minimum": 0},
        "candidate_builds": {"type": "integer", "minimum": 0},
        "human_messages": {"type": "integer", "minimum": 0},
        "human_minutes": {"type": "number", "minimum": 0}
      }
    }
  }
}
