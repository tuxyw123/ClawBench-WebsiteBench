{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawbench.local/schemas/websitebench.driver.v1.json",
  "title": "Private WebsiteBench SiteDriver",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "site_id", "family_id", "variant_id", "site_version",
    "public_manifest", "compose", "service_roles", "networks", "urls",
    "environment", "mounts", "candidate_runtime", "evaluator", "scoring"
  ],
  "properties": {
    "schema_version": {"const": "websitebench.driver.v1"},
    "site_id": {"$ref": "#/$defs/id"},
    "family_id": {"$ref": "#/$defs/id"},
    "variant_id": {"$ref": "#/$defs/id"},
    "site_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "public_manifest": {"$ref": "#/$defs/path"},
    "compose": {"$ref": "#/$defs/path"},
    "service_roles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference", "mailbox_query", "mailbox_delivery", "build_daemon",
        "candidate_builder", "browser_gateway", "model_proxy", "agent", "evaluator"
      ],
      "properties": {
        "reference": {"$ref": "#/$defs/service"},
        "mailbox_query": {"$ref": "#/$defs/service"},
        "mailbox_delivery": {"$ref": "#/$defs/service"},
        "build_daemon": {"$ref": "#/$defs/service"},
        "candidate_builder": {"$ref": "#/$defs/service"},
        "browser_gateway": {"$ref": "#/$defs/service"},
        "model_proxy": {"$ref": "#/$defs/service"},
        "agent": {"$ref": "#/$defs/service"},
        "evaluator": {"$ref": "#/$defs/service"}
      }
    },
    "networks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_control", "reference_web", "candidate_web", "model_egress", "build_egress", "internet_egress"],
      "properties": {
        "agent_control": {"$ref": "#/$defs/service"},
        "reference_web": {"$ref": "#/$defs/service"},
        "candidate_web": {"$ref": "#/$defs/service"},
        "model_egress": {"$ref": "#/$defs/service"},
        "build_egress": {"$ref": "#/$defs/service"},
        "internet_egress": {"$ref": "#/$defs/service"}
      }
    },
    "urls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "mailbox", "browser_gateway", "candidate"],
      "properties": {
        "target": {"$ref": "#/$defs/url"},
        "mailbox": {"$ref": "#/$defs/url"},
        "browser_gateway": {"$ref": "#/$defs/url"},
        "candidate": {"$ref": "#/$defs/url"}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "host_secret_allowlist"],
      "properties": {
        "candidate": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/typed_value"}
        },
        "host_secret_allowlist": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"}
        }
      }
    },
    "mounts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "kind", "read_only", "roles"],
        "properties": {
          "source": {"$ref": "#/$defs/path"},
          "target": {"type": "string", "pattern": "^/", "not": {"pattern": "(?:^|/)\\.\\.(?:/|$)"}},
          "kind": {"enum": ["public", "private_reference", "private_fixture", "private_evaluator", "private_assertions", "private_variant", "artifact"]},
          "read_only": {"type": "boolean"},
          "roles": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"enum": ["reference", "mailbox_query", "mailbox_delivery", "build_daemon", "candidate_builder", "browser_gateway", "model_proxy", "agent", "evaluator"]}
          }
        }
      }
    },
    "candidate_runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image_prefix", "container_prefix", "volume_prefix", "hostname", "network_role", "limits", "health", "admin", "fixture_mount", "schema_mount"],
      "properties": {
        "image_prefix": {"type": "string", "minLength": 1},
        "container_prefix": {"type": "string", "minLength": 1},
        "volume_prefix": {"type": "string", "minLength": 1},
        "hostname": {"$ref": "#/$defs/service"},
        "network_role": {"const": "candidate_web"},
        "limits": {
          "type": "object", "additionalProperties": false,
          "required": ["pids", "memory", "cpus", "tmpfs"],
          "properties": {
            "pids": {"type": "integer", "minimum": 1},
            "memory": {"type": "string", "minLength": 1},
            "cpus": {"type": "number", "exclusiveMinimum": 0},
            "tmpfs": {"type": "string", "minLength": 1}
          }
        },
        "health": {
          "type": "object", "additionalProperties": false,
          "required": ["timeout_seconds", "accepted_states"],
          "properties": {
            "timeout_seconds": {"type": "integer", "minimum": 1},
            "accepted_states": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
          }
        },
        "admin": {
          "type": "object", "additionalProperties": false,
          "required": ["port_env", "token_env"],
          "properties": {"port_env": {"type": "string"}, "token_env": {"type": "string"}}
        },
        "fixture_mount": {"type": "string", "pattern": "^/"},
        "schema_mount": {"type": "string", "pattern": "^/"}
      }
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "argv", "environment", "facts_path"],
      "properties": {
        "profile": {"type": "string", "minLength": 1},
        "argv": {"type": "array", "items": {"type": "string"}},
        "environment": {
          "type": "object",
          "propertyNames": {"pattern": "^[A-Z][A-Z0-9_]*$"},
          "additionalProperties": {"type": "string"}
        },
        "facts_path": {"type": "string", "pattern": "^/"}
      }
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "facts_schema", "result_schema"],
      "properties": {
        "policy": {"$ref": "#/$defs/path"},
        "facts_schema": {"$ref": "#/$defs/path"},
        "result_schema": {"$ref": "#/$defs/path"}
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "service": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)", "not": {"pattern": "(?:^|/)\\.\\.(?:/|$)"}},
    "url": {"type": "string", "format": "uri", "pattern": "^https?://"},
    "typed_value": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {"enum": ["string", "integer", "boolean", "url", "path"]},
        "value": {},
        "minimum": {"type": "integer"},
        "maximum": {"type": "integer"}
      }
    }
  }
}
