{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawbench.local/schemas/websitebench.fixture.v1.json",
  "title": "Northstar Market deterministic fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fixture_id", "seed", "now", "catalog", "accounts", "scenario"],
  "properties": {
    "schema_version": {"const": "websitebench.fixture.v1"},
    "fixture_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "seed": {"type": "integer", "minimum": 0},
    "now": {"$ref": "#/$defs/utc_timestamp"},
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categories", "products"],
      "properties": {
        "categories": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {"$ref": "#/$defs/category"}
        },
        "products": {
          "type": "array",
          "minItems": 48,
          "maxItems": 48,
          "items": {"$ref": "#/$defs/product"}
        }
      }
    },
    "accounts": {
      "type": "array",
      "minItems": 4,
      "items": {"$ref": "#/$defs/account"}
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["exploration", "smoke", "functional", "concurrency"]},
        "content_salt": {"type": "string", "minLength": 1},
        "stock_one_product_id": {"type": ["string", "null"], "pattern": "^prod_[a-z0-9_]+$"}
      }
    }
  },
  "$defs": {
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "identifier": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug", "name", "description", "image"],
      "properties": {
        "id": {"type": "string", "pattern": "^cat_[a-z0-9_]+$"},
        "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "name": {"type": "string", "minLength": 1, "maxLength": 80},
        "description": {"type": "string", "minLength": 1, "maxLength": 240},
        "image": {"$ref": "#/$defs/image"}
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "sku", "slug", "title", "brand", "description",
        "category_id", "tags", "price_cents", "compare_at_cents",
        "inventory", "rating_basis_points", "review_count", "featured_rank", "image"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^prod_[a-z0-9_]+$"},
        "sku": {"type": "string", "pattern": "^[A-Z0-9-]{4,32}$"},
        "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "title": {"type": "string", "minLength": 3, "maxLength": 140},
        "brand": {"type": "string", "minLength": 1, "maxLength": 60},
        "description": {"type": "string", "minLength": 20, "maxLength": 1200},
        "category_id": {"type": "string", "pattern": "^cat_[a-z0-9_]+$"},
        "tags": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 40}
        },
        "price_cents": {"type": "integer", "minimum": 100, "maximum": 999999},
        "compare_at_cents": {"type": ["integer", "null"], "minimum": 100, "maximum": 999999},
        "inventory": {"type": "integer", "minimum": 0, "maximum": 9999},
        "rating_basis_points": {"type": "integer", "minimum": 0, "maximum": 500},
        "review_count": {"type": "integer", "minimum": 0, "maximum": 999999},
        "featured_rank": {"type": "integer", "minimum": 1, "maximum": 48},
        "image": {"$ref": "#/$defs/image"}
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "key", "background", "accent"],
      "properties": {
        "kind": {"const": "generated-svg"},
        "key": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
        "background": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
        "accent": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "email", "password", "verified", "full_name"],
      "properties": {
        "id": {"type": "string", "pattern": "^user_[a-z0-9_]+$"},
        "email": {"type": "string", "format": "email", "maxLength": 254},
        "password": {"type": "string", "minLength": 10, "maxLength": 200},
        "verified": {"type": "boolean"},
        "full_name": {"type": "string", "minLength": 1, "maxLength": 120}
      }
    }
  }
}
