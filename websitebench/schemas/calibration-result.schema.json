{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawbench.local/schemas/websitebench.calibration-result.v1.json",
  "title": "Unranked external-harness calibration result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "calibration_id", "benchmark_id", "model", "reasoning_effort", "track", "time_limit_seconds", "status", "mandatory_task_passed", "steps", "usage", "elapsed_seconds", "harness_error", "started_at", "finished_at"],
  "properties": {
    "schema_version": {"const": "websitebench.calibration-result.v1"},
    "calibration_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "benchmark_id": {"const": "amazon-136"},
    "model": {"type": "string", "minLength": 1},
    "reasoning_effort": {"enum": ["xhigh", "high", "medium", "low"]},
    "track": {"const": "core"},
    "time_limit_seconds": {"const": 1200},
    "status": {"enum": ["PASS", "FAIL", "HARNESS_ERROR"]},
    "mandatory_task_passed": {"type": "boolean"},
    "steps": {
      "type": "object", "additionalProperties": false,
      "required": ["passed", "total", "pass_rate"],
      "properties": {
        "passed": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 1},
        "pass_rate": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "usage": {
      "type": "object", "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "browser_actions"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "browser_actions": {"type": "integer", "minimum": 0}
      }
    },
    "elapsed_seconds": {"type": "number", "minimum": 0},
    "harness_error": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {"code": {"type": "string", "minLength": 1}, "message": {"type": "string", "minLength": 1}}
        }
      ]
    },
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "PASS"}}}, "then": {"properties": {"mandatory_task_passed": {"const": true}, "harness_error": {"type": "null"}}}},
    {"if": {"properties": {"status": {"const": "HARNESS_ERROR"}}}, "then": {"properties": {"mandatory_task_passed": {"const": false}, "harness_error": {"type": "object"}}}}
  ]
}
