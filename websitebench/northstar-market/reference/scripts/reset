#!/bin/sh
set -eu

: "${BENCH_ADMIN_TOKEN:?BENCH_ADMIN_TOKEN is required}"
ADMIN_URL="${ADMIN_URL:-http://127.0.0.1:8081}"
SEED="${SEED:-1101}"
RUN_ID="${RUN_ID:-northstar-manual-reset}"
NOW="${NOW:-2026-01-15T12:00:00Z}"

curl --fail --silent --show-error \
  -H "X-Bench-Admin-Token: ${BENCH_ADMIN_TOKEN}" \
  -H "Content-Type: application/json" \
  -d "{\"schema_version\":1,\"run_id\":\"${RUN_ID}\",\"seed\":${SEED},\"now\":\"${NOW}\",\"fixture_path\":\"/bench-fixtures/${SEED}.json\"}" \
  "${ADMIN_URL}/__bench/reset"

