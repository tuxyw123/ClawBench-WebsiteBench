{
  "schema_version": "websitebench.scoring.v1",
  "site_version": "1.0.0",
  "hard_failure_score": 0,
  "dimensions": {
    "visual": {
      "max_score": 20,
      "aggregation": "mean checkpoint similarity times max_score",
      "checkpoint_metrics": {
        "ssim": 0.30,
        "edge_f1": 0.20,
        "color_histogram": 0.15,
        "text": 0.20,
        "geometry": 0.15
      },
      "checkpoint_file": "visual-checkpoints.json"
    },
    "interactions": {
      "max_score": 20,
      "aggregation": "passed assertions divided by total assertions times max_score",
      "groups": [
        "header-and-navigation",
        "responsive-menu-and-keyboard",
        "search-query-and-history",
        "category-filter",
        "sorting-and-pagination",
        "product-stock-controls",
        "cart-quantity-and-remove",
        "form-validation-and-feedback",
        "loading-and-double-submit-guard",
        "empty-error-and-success-states"
      ]
    },
    "journeys": {
      "max_score": 40,
      "aggregation": "sum of eight journey scores",
      "journey_max_score": 5,
      "terminal_failure_cap": 2.5,
      "journeys": [
        "catalog-search-and-product",
        "registration-verification-and-login",
        "session-lifecycle-and-safe-redirect",
        "password-reset-and-session-invalidation",
        "guest-cart-persistence-and-login-merge",
        "checkout-decline-success-and-idempotency",
        "order-history-detail-isolation-and-restart",
        "cancellation-window-and-inventory-restock"
      ]
    },
    "robustness": {
      "max_score": 15,
      "aggregation": "one point per passing group",
      "groups": [
        "registration-input-validation-does-not-throttle",
        "email-or-device-throttle-five-minute-boundary",
        "verification-expiry-tamper-and-single-use",
        "reset-expiry-tamper-and-single-use",
        "session-expiry-and-reset-invalidation",
        "safe-next-path-and-no-open-redirect",
        "cart-stock-and-five-unit-cap",
        "cart-merge-is-retry-safe",
        "declined-payment-is-side-effect-free",
        "invalid-and-expired-test-card",
        "atomic-all-or-nothing-stock-shortage",
        "checkout-idempotency-under-retry",
        "cancellation-boundary-and-repeat-safety",
        "cross-account-order-is-404",
        "concurrent-stock-one-purchase"
      ]
    },
    "efficiency": {
      "max_score": 5,
      "aggregation": "one point per satisfied target",
      "targets": {
        "clean_build_seconds": {"operator": "<=", "value": 600},
        "image_bytes": {"operator": "<=", "value": 1610612736},
        "peak_memory_bytes": {"operator": "<=", "value": 1073741824},
        "p95_latency_ms_at_10_concurrent": {"operator": "<=", "value": 1000},
        "source_bytes": {"operator": "<=", "value": 52428800}
      }
    }
  },
  "hard_failures": [
    "candidate-build-failed",
    "candidate-startup-failed",
    "public-health-failed",
    "admin-health-or-reset-failed",
    "reference-iframe-proxy-or-redirect",
    "runtime-reference-request",
    "runtime-internet-request",
    "remote-screenshot-or-content-service",
    "private-source-asset-bundle-cache-or-profile-copy",
    "no-real-persistent-backend",
    "public-admin-api-or-token-exposure",
    "privileged-host-network-docker-socket-or-host-mount"
  ]
}
