{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "website-bench-viewer",
  "main": "./src/index.js",
  "compatibility_date": "2026-07-23",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "website-bench.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "404-page"
  }
}
